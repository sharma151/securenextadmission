# --- Next.js & Turbopack ---
.next/
out/
build/
# Turbopack's native engine cache (v15+)
.turbo/
# Next.js 16 concurrent execution lockfile
.next-lock.json

# --- Tailwind CSS v4 ---
# Tailwind v4 handles prefixing & imports natively; 
# ignore its internal build artifacts if you use the CLI
.tailwindcss/

# --- Dependencies ---
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
# Keep these if you use Yarn Berry (Zero-installs)
# !.yarn/cache 

# --- Logs & Debugging ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
*.log
# New in 2026: TypeScript build info
*.tsbuildinfo

# --- Environment Variables (CRITICAL) ---
.env*
!.env.example

# --- IDE & System ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
*.swp

# --- Docker ---
.docker/
docker-compose.override.yml